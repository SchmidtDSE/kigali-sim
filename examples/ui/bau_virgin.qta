start default

  define application "app1"

    uses substance "sub1"
      enable domestic
      enable import
      initial charge with 5 kg / unit for domestic
      initial charge with 5 kg / unit for import
      set virgin to 100 mt
      equals 5 tCO2e / mt
    end substance

  end application

end default


start simulations

  simulate "business as usual" from years 1 to 5

end simulations
